<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:WidePlay.ViewModels"
             x:Class="WidePlay.Views.PlayerPage"
             x:DataType="vm:PlayerViewModel"
             BackgroundColor="#141414"
             Shell.NavBarIsVisible="False">

    <Grid Padding="28" RowDefinitions="*,Auto,Auto,Auto,Auto,Auto,*,Auto" RowSpacing="18">

        <!-- Album art -->
        <Border Grid.Row="1" WidthRequest="260" HeightRequest="260"
                HorizontalOptions="Center" StrokeThickness="0"
                StrokeShape="RoundRectangle 18" BackgroundColor="#1E1E1E">
            <Image Source="{Binding CurrentSong.AlbumArtUrl}" Aspect="AspectFill" />
        </Border>

        <!-- Song info -->
        <VerticalStackLayout Grid.Row="2" Spacing="4" Margin="0,16,0,0">
            <Label Text="{Binding CurrentSong.Title, FallbackValue='Nothing playing'}"
                   FontSize="24" FontAttributes="Bold" TextColor="White"
                   HorizontalOptions="Center" HorizontalTextAlignment="Center" />
            <Label Text="{Binding CurrentSong.Artist}" FontSize="16"
                   TextColor="#919191" HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- Progress -->
        <ProgressBar Grid.Row="3" Progress="{Binding ProgressValue}"
                     ProgressColor="#512BD4" Margin="0,8,0,0" />

        <!-- Listener count -->
        <Label Grid.Row="4" Text="{Binding ListenerLabel}" FontSize="13"
               TextColor="#6E6E6E" HorizontalOptions="Center" />

        <!-- Controls -->
        <HorizontalStackLayout Grid.Row="5" Spacing="28" HorizontalOptions="Center" Margin="0,8,0,0">
            <Button Text="⏮" Command="{Binding SkipPreviousCommand}"
                    BackgroundColor="Transparent" TextColor="White" FontSize="28"
                    WidthRequest="60" HeightRequest="60" />
            <Button Text="{Binding PlayPauseGlyph}" Command="{Binding PlayPauseCommand}"
                    BackgroundColor="#512BD4" TextColor="White" FontSize="26"
                    WidthRequest="72" HeightRequest="72" CornerRadius="36" />
            <Button Text="⏭" Command="{Binding SkipNextCommand}"
                    BackgroundColor="Transparent" TextColor="White" FontSize="28"
                    WidthRequest="60" HeightRequest="60" />
        </HorizontalStackLayout>

        <!-- Bottom actions -->
        <VerticalStackLayout Grid.Row="7" Spacing="8" VerticalOptions="End">
            <Button Text="Search Song"
                    Command="{Binding SearchSongCommand}"
                    BackgroundColor="#1E1E1E" TextColor="White"
                    FontSize="16" HeightRequest="52" CornerRadius="14" />
            <Button Text="End Session"
                    Command="{Binding EndSessionCommand}"
                    BackgroundColor="Transparent" TextColor="#FF5A5A"
                    FontSize="15" HeightRequest="44" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
