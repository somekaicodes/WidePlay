<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="WidePlay.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:WidePlay.Views"
    Title="Wide Play"
    FlyoutBehavior="Disabled">

    <!-- Each page is an absolute route reachable via GoToAsync("//PageName").
         The app drives navigation in code from the ViewModels, so the flyout is disabled. -->
    <ShellContent Route="HomePage" ContentTemplate="{DataTemplate views:HomePage}" />
    <ShellContent Route="PlayerPage" ContentTemplate="{DataTemplate views:PlayerPage}" />
    <ShellContent Route="PeerPage" ContentTemplate="{DataTemplate views:PeerPage}" />
    <ShellContent Route="SearchPage" ContentTemplate="{DataTemplate views:SearchPage}" />

</Shell>
